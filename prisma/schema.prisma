generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model TripDay {
  id         String         @id @default(cuid())
  dayNumber  Int            @unique
  title      String
  region     String
  haiku      String?
  activities TripActivity[]
  dayNotes   DayNote[]
}

model TripActivity {
  id          String          @id @default(cuid())
  dayId       String
  sortOrder   Int
  title       String
  time        String
  type        String
  description String
  lat         Float
  lng         Float
  optional    Boolean         @default(false)
  duration    String?
  day         TripDay         @relation(fields: [dayId], references: [id], onDelete: Cascade)
  states      ActivityState[]
}

model ActivityState {
  id          String       @id @default(cuid())
  userId      String
  activityId  String
  isDone      Boolean      @default(false)
  customTitle String?
  customTime  String?
  customDesc  String?
  activity    TripActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([userId, activityId])
}

model AiSuggestion {
  id          String   @id @default(cuid())
  userId      String
  day         Int
  title       String
  time        String
  type        String
  lat         Float
  lng         Float
  description String
  createdAt   DateTime @default(now())
}

model DayNote {
  id        String   @id @default(cuid())
  userId    String
  dayId     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  day       TripDay  @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@unique([userId, dayId])
}

model Reservation {
  id          String   @id @default(cuid())
  userId      String
  name        String
  date        String
  time        String?
  confirmNo   String?
  notes       String?
  activityKey String?
  createdAt   DateTime @default(now())
}

model AiUsageLog {
  id        String   @id @default(cuid())
  userId    String
  feature   String
  createdAt DateTime @default(now())
}
