generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ── NextAuth ──────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String?
  image          String?
  accounts       Account[]
  sessions       Session[]
  activityStates ActivityState[]
  aiSuggestions  AiSuggestion[]
  dayNotes       DayNote[]
  reservations   Reservation[]
  aiUsageLogs    AiUsageLog[]
  createdAt      DateTime        @default(now())
}

// ── Trip data ─────────────────────────────────────────────────────────────────

model TripDay {
  id         String         @id @default(cuid())
  dayNumber  Int            @unique
  title      String
  region     String
  haiku      String?
  activities TripActivity[]
  dayNotes   DayNote[]
}

model TripActivity {
  id          String          @id @default(cuid())
  dayId       String
  sortOrder   Int
  title       String
  time        String
  type        String
  description String
  lat         Float
  lng         Float
  optional    Boolean         @default(false)
  duration    String?
  day         TripDay         @relation(fields: [dayId], references: [id], onDelete: Cascade)
  states      ActivityState[]
}

// ── Per-user trip state (shared across couple via scoping) ────────────────────

model ActivityState {
  id          String       @id @default(cuid())
  userId      String
  activityId  String
  isDone      Boolean      @default(false)
  customTitle String?
  customTime  String?
  customDesc  String?
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity    TripActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([userId, activityId])
}

model AiSuggestion {
  id          String   @id @default(cuid())
  userId      String
  day         Int
  title       String
  time        String
  type        String
  lat         Float
  lng         Float
  description String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DayNote {
  id        String   @id @default(cuid())
  userId    String
  dayId     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  day       TripDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@unique([userId, dayId])
}

model Reservation {
  id          String   @id @default(cuid())
  userId      String
  name        String
  date        String
  time        String?
  confirmNo   String?
  notes       String?
  activityKey String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AiUsageLog {
  id        String   @id @default(cuid())
  userId    String
  feature   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
