# Database (Neon Postgres)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Gemini AI
GEMINI_API_KEY=

# Allowed users (comma-separated emails — leave empty to allow all authenticated users)
ALLOWED_EMAILS=your@email.com,partner@email.com

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
